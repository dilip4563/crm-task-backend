generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  EMPLOYEE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  WAITING_APPROVAL
  COMPLETED
  OVERDUE
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_COMPLETED
  TASK_OVERDUE
  TASK_COMMENTED
  EMPLOYEE_CREATED
  TASK_UPDATED
  PASSWORD_RESET
  ATTENDANCE_LATE
  CORRECTION_REQUEST
  CORRECTION_REVIEWED
}

enum CorrectionType {
  MISSED_LOGIN
  MISSED_LOGOUT
  WRONG_ENTRY
}

enum CorrectionStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id                String    @id @default(uuid())
  username          String    @unique
  email             String    @unique
  passwordHash      String
  role              Role      @default(EMPLOYEE)
  firstName         String
  lastName          String
  phone             String?
  avatar            String?
  department        String?

  managerId         String?
  manager           User?     @relation("Team", fields: [managerId], references: [id])
  teamMembers       User[]    @relation("Team")
  isActive          Boolean   @default(true)
  mustChangePassword Boolean  @default(true)
  lastLogin         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  assignedTasks     Task[]    @relation("AssignedTo")
  createdTasks      Task[]    @relation("CreatedBy")
  comments          TaskComment[]
  notifications     Notification[] @relation("NotifRecipient")
  sentNotifications Notification[] @relation("NotifSender")
  activityLogs      ActivityLog[]
  attendanceSessions AttendanceSession[]
  breakSessions      BreakSession[]
  corrections        AttendanceCorrection[] @relation("CorrectionUser")
  reviewedCorrections AttendanceCorrection[] @relation("CorrectionReviewer")
}

model Task {
  id           String       @id @default(uuid())
  title        String
  description  String?
  priority     TaskPriority @default(MEDIUM)
  status       TaskStatus   @default(NOT_STARTED)
  dueAt        DateTime
  notes        String?
  completedAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  assignedToId String
  assignedTo   User         @relation("AssignedTo", fields: [assignedToId], references: [id])
  createdById  String
  createdBy    User         @relation("CreatedBy", fields: [createdById], references: [id])

  comments     TaskComment[]
  attachments  TaskAttachment[]
  activityLogs ActivityLog[]
  notifications Notification[]
}

model TaskComment {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
}

model TaskAttachment {
  id           String   @id @default(uuid())
  filename     String
  url          String
  mimeType     String?
  size         Int?
  createdAt    DateTime @default(now())

  taskId       String
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Notification {
  id          String           @id @default(uuid())
  type        NotificationType
  title       String
  message     String
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())

  recipientId String
  recipient   User             @relation("NotifRecipient", fields: [recipientId], references: [id])
  senderId    String?
  sender      User?            @relation("NotifSender", fields: [senderId], references: [id])
  taskId      String?
  task        Task?            @relation(fields: [taskId], references: [id], onDelete: SetNull)
}

model AttendanceSession {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  date      String    // YYYY-MM-DD (office local date)
  loginAt   DateTime
  logoutAt  DateTime?
  ip        String?
  device    String?
  manual    Boolean   @default(false) // created via approved correction
  createdAt DateTime  @default(now())

  @@index([userId, date])
}

model BreakSession {
  id      String    @id @default(uuid())
  userId  String
  user    User      @relation(fields: [userId], references: [id])
  date    String
  startAt DateTime
  endAt   DateTime?

  @@index([userId, date])
}

model AttendanceCorrection {
  id               String           @id @default(uuid())
  userId           String
  user             User             @relation("CorrectionUser", fields: [userId], references: [id])
  date             String
  type             CorrectionType
  requestedLoginAt  DateTime?
  requestedLogoutAt DateTime?
  reason           String
  status           CorrectionStatus @default(PENDING)
  reviewedById     String?
  reviewedBy       User?            @relation("CorrectionReviewer", fields: [reviewedById], references: [id])
  reviewedAt       DateTime?
  createdAt        DateTime         @default(now())
}

model WorkSettings {
  id           Int    @id @default(1)
  workStart    String @default("09:30")
  lateAfter    String @default("09:45")
  workEnd      String @default("18:30")
  fullDayHours Float  @default(8)
  halfDayHours Float  @default(4)
  timezone     String @default("Asia/Kolkata")
}

model ActivityLog {
  id          String   @id @default(uuid())
  action      String
  description String
  metadata    Json?
  createdAt   DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id])
  taskId      String?
  task        Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
}
